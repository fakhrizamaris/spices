# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.my.id

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin Auth ───────────────────────────────────────────────────────────────
# Simple password protecting the /admin section (no Supabase Auth needed).
ADMIN_PASSWORD=change_this_to_a_strong_password
# Cookie name — only change if there's a conflict
ADMIN_SESSION_COOKIE=admin_session

# ── Cloudinary (optional — only needed if using Cloudinary CDN) ───────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Resend — for inquiry notifications) ────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
INQUIRY_NOTIFICATION_EMAIL=admin@yourdomain.my.id

# ── Vercel ────────────────────────────────────────────────────────────────────
# Set automatically by Vercel — do not set manually in Vercel dashboard
# VERCEL_URL=yourdomain.my.id
